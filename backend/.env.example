# backend/.env.example
# Database
DATABASE_URL=postgresql://postgres:admin@localhost:5432/jira_ai_agent

# JWT
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OTP (hardcoded for now)
OTP_CODE=1234

# Jira
JIRA_BASE_URL=http://localhost:8080
JIRA_USERNAME=admin
JIRA_PASSWORD=admin

# n8n
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook
DUMMY_MODE=true

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
